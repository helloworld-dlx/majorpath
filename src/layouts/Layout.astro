---
import HeaderSearch from '../components/HeaderSearch';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "用说大白话的方式，帮高中生看懂大学专业、找到方向，少一点盲选" } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | 专业不迷路</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#3b82f6" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col bg-bg text-text antialiased">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-border">
      <div class="max-w-5xl mx-auto px-4 h-16 flex items-center relative">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group shrink-0">
          <div class="w-9 h-9 rounded-lg bg-primary flex items-center justify-center shadow-sm group-hover:shadow transition-shadow">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <span class="font-semibold text-slate-900 text-lg">专业不迷路</span>
        </a>

        <!-- Desktop center search (md+) -->
        <div class="hidden md:block absolute left-1/2 -translate-x-1/2 w-72">
          <HeaderSearch client:idle />
        </div>

        <!-- Right side -->
        <div class="flex items-center gap-1 ml-auto">
          <!-- Desktop right nav (md+) -->
          <nav class="hidden md:flex items-center gap-1">
            <a href="/majors" class="px-3 py-2 text-sm font-medium text-slate-600 hover:text-primary rounded-lg hover:bg-primary-light/50 transition-colors">
              专业目录
            </a>
            <a href="/test" class="px-3 py-2 text-sm font-medium text-slate-600 hover:text-primary rounded-lg hover:bg-primary-light/50 transition-colors">
              方向测试
            </a>
            <a href="/about" class="px-3 py-2 text-sm font-medium text-slate-600 hover:text-primary rounded-lg hover:bg-primary-light/50 transition-colors">
              关于项目
            </a>
            <a href="/contribute" class="px-3 py-2 text-sm font-medium text-slate-600 hover:text-primary rounded-lg hover:bg-primary-light/50 transition-colors">
              共建我们
            </a>
          </nav>
          <!-- Mobile search -->
          <div class="md:hidden">
            <HeaderSearch client:idle />
          </div>
          <button
            type="button"
            class="md:hidden p-2 -mr-2 text-slate-500 hover:text-slate-700 rounded-lg hover:bg-secondary-light transition-colors"
            aria-label="菜单"
            id="mobile-menu-btn"
          >
            <svg id="menu-icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile nav dropdown -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-white">
        <nav class="px-3 py-3 space-y-1">
          <a href="/majors" class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-slate-700 hover:text-primary hover:bg-primary-light/50 rounded-xl transition-colors active:scale-[0.98]">
            <span class="text-base">📚</span> 专业目录
          </a>
          <a href="/test" class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-slate-700 hover:text-primary hover:bg-primary-light/50 rounded-xl transition-colors active:scale-[0.98]">
            <span class="text-base">🧭</span> 方向测试
          </a>
          <a href="/about" class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-slate-700 hover:text-primary hover:bg-primary-light/50 rounded-xl transition-colors active:scale-[0.98]">
            <span class="text-base">💡</span> 关于项目
          </a>
          <a href="/contribute" class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-slate-700 hover:text-primary hover:bg-primary-light/50 rounded-xl transition-colors active:scale-[0.98]">
            <span class="text-base">🤝</span> 共建我们
          </a>
        </nav>
        <!-- Mobile bottom hint -->
        <div class="px-4 py-3 border-t border-slate-50">
          <p class="text-[11px] text-slate-400 text-center">
            公益项目 · 核心功能免费
          </p>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-auto bg-bg-alt border-t border-border">
      <div class="max-w-5xl mx-auto px-4 py-8">
        <!-- Main footer content -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-6">
          <!-- Brand -->
          <div>
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
              <span class="font-semibold text-slate-900">专业不迷路</span>
            </div>
            <p class="text-sm text-slate-500 leading-relaxed">
              公益型专业认知小站，核心功能免费。<br />
              用说大白话的方式，帮高中生看懂专业、找到方向。
            </p>
          </div>

          <!-- Quick links -->
          <div>
            <h4 class="text-sm font-semibold text-slate-700 mb-3">快速入口</h4>
            <nav class="grid grid-cols-2 sm:grid-cols-1 gap-2">
              <a href="/majors" class="text-sm text-slate-500 hover:text-primary transition-colors">专业目录</a>
              <a href="/test" class="text-sm text-slate-500 hover:text-primary transition-colors">方向测试</a>
              <a href="/contribute" class="text-sm text-slate-500 hover:text-primary transition-colors">共建我们</a>
              <a href="/about" class="text-sm text-slate-500 hover:text-primary transition-colors">关于项目</a>
            </nav>
          </div>

          <!-- Legal -->
          <div>
            <h4 class="text-sm font-semibold text-slate-700 mb-3">使用说明</h4>
            <p class="text-sm text-slate-500 leading-relaxed">
              本站不提供录取概率预测，不替代正式志愿填报建议。最终选择请结合分数、位次、院校、家庭情况综合判断。
            </p>
          </div>
        </div>

        <!-- Contact row -->
        <div class="border-t border-border pt-5 mb-6">
          <h4 class="text-sm font-semibold text-slate-700 mb-3">📬 联系我们</h4>
          <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-slate-500">
            <span class="inline-flex items-center gap-1.5">
              <span class="text-blue-500">🐧</span> QQ <code class="bg-slate-100 px-1.5 py-0.5 rounded text-slate-600">1531371420</code>
            </span>
            <span class="inline-flex items-center gap-1.5">
              <span class="text-green-500">💬</span> 微信 <code class="bg-slate-100 px-1.5 py-0.5 rounded text-slate-600">helloworld-dlx</code>
            </span>
            <a href="https://github.com/helloworld-dlx" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-slate-500 hover:text-primary transition-colors">
              <span class="text-purple-500">🐙</span> GitHub <span class="underline underline-offset-2">@helloworld-dlx</span>
            </a>
          </div>
        </div>

        <!-- Bottom bar -->
        <div class="pt-6 border-t border-border text-center">
          <p class="text-sm text-slate-400">
            专业不迷路 · 核心功能免费 · 不制造焦虑 · 不商业导流
          </p>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle with icon swap + scroll lock
      (function () {
        var btn = document.getElementById('mobile-menu-btn');
        var menu = document.getElementById('mobile-menu');
        var iconOpen = document.getElementById('menu-icon-open');
        var iconClose = document.getElementById('menu-icon-close');
        if (!btn || !menu) return;

        btn.addEventListener('click', function () {
          var isOpen = !menu.classList.contains('hidden');
          if (isOpen) {
            menu.classList.add('hidden');
            if (iconOpen) iconOpen.classList.remove('hidden');
            if (iconClose) iconClose.classList.add('hidden');
            document.body.style.overflow = '';
          } else {
            menu.classList.remove('hidden');
            if (iconOpen) iconOpen.classList.add('hidden');
            if (iconClose) iconClose.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
          }
        });

        // Close menu when tapping a link
        menu.querySelectorAll('a').forEach(function (link) {
          link.addEventListener('click', function () {
            menu.classList.add('hidden');
            if (iconOpen) iconOpen.classList.remove('hidden');
            if (iconClose) iconClose.classList.add('hidden');
            document.body.style.overflow = '';
          });
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
