---
import type { MajorDetailContent } from '../../types/major-detail';
import StatusBadge from './StatusBadge.astro';

interface Props {
  content: MajorDetailContent;
  /** 内容审核状态 */
  reviewStatus?: 'draft' | 'reviewed';
  /** 当前专业名称（在"容易混淆的专业"中显示对比对象） */
  currentName?: string;
}

const { content: c, reviewStatus, currentName } = Astro.props;
const isDraft = reviewStatus === 'draft' || reviewStatus === undefined;
---

<article class="space-y-5">

  <!-- ═══ 头部 ═══ -->
  <header class="border-b border-slate-100 pb-6">
    <h1 class="text-2xl font-bold text-slate-900 mb-3">
      {c.oneLiner}
    </h1>
    {isDraft && (
      <div class="inline-flex items-center gap-1.5 text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded-full px-3 py-1">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        内容为 AI 生成初稿，未经人工审核。详见 REVIEW_CHECKLIST.md
      </div>
    )}
  </header>

  <!-- ═══ 1. 相关介绍视频（如果存在） ═══ -->
  {
    (c.videos && c.videos.length > 0) ? (
      <section class="bg-white p-5 sm:p-6 rounded-xl border border-slate-200 shadow-sm">
        <h2 class="font-semibold text-slate-800 mb-1 flex items-center gap-2 text-base">
          <span class="text-lg">🎬</span>先看个视频了解一下
        </h2>
        <p class="text-xs text-slate-400 mb-4">以下视频来自网络，仅供参考了解，不代表本站立场</p>
        <div class="grid sm:grid-cols-2 gap-3">
          {c.videos.map((v) => (
            <a
              href={v.url}
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="group block p-4 rounded-xl border border-slate-100 bg-slate-50/80 hover:bg-slate-50 hover:border-primary/20 transition-all"
            >
              <div class="flex items-start gap-2 mb-2">
                <span class="shrink-0 mt-0.5 text-slate-300 group-hover:text-primary/60 transition-colors">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </span>
                <span class="text-sm font-medium text-slate-700 group-hover:text-primary transition-colors leading-snug">{v.title}</span>
              </div>
              <p class="text-xs text-slate-500 leading-relaxed">{v.intro}</p>
            </a>
          ))}
        </div>
      </section>
    ) : (
      <section class="bg-slate-50/60 p-4 rounded-xl border border-dashed border-slate-200 text-center">
        <p class="text-xs text-slate-400 leading-relaxed">
          <span class="mr-1">🎬</span>相关视频待补充，欢迎
          <a href="/contribute" class="text-primary hover:underline mx-0.5">推荐优质内容</a>
        </p>
      </section>
    )
  }

  <!-- ═══ 2. 专业到底学什么 ═══ -->
  <section class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
    <h2 class="font-semibold text-slate-800 mb-3 flex items-center gap-2 text-base">
      <span class="text-lg">📖</span>大学大概学什么
    </h2>
    <ul class="space-y-2">
      {c.whatYouLearn.map((item) => (
        <li class="flex gap-2 text-sm text-slate-600 leading-relaxed">
          <span class="text-slate-300 mt-0.5 shrink-0">•</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- ═══ 3. 和高中有什么不同 ═══ -->
  <section class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
    <h2 class="font-semibold text-slate-800 mb-3 flex items-center gap-2 text-base">
      <span class="text-lg">📐</span>和高中学科有什么不同
    </h2>
    <ul class="space-y-2">
      {c.vsHighSchool.map((item) => (
        <li class="flex gap-2 text-sm text-slate-600 leading-relaxed">
          <span class="text-slate-300 mt-0.5 shrink-0">•</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- ═══ 4. 适合什么样的人 ═══ -->
  <section class="bg-emerald-50/50 p-5 rounded-xl border border-emerald-100">
    <h2 class="font-semibold text-emerald-800 mb-3 flex items-center gap-2 text-base">
      <span class="text-lg">✅</span>适合什么样的人
    </h2>
    <ul class="space-y-2">
      {c.suitableFor.map((item) => (
        <li class="flex gap-2 text-sm text-slate-700 leading-relaxed">
          <span class="text-emerald-400 mt-0.5 shrink-0">•</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- ═══ 5. 不太适合什么样的人 ═══ -->
  <section class="bg-rose-50/50 p-5 rounded-xl border border-rose-100">
    <h2 class="font-semibold text-rose-700 mb-3 flex items-center gap-2 text-base">
      <span class="text-lg">🤔</span>不太适合什么样的人
    </h2>
    <p class="text-xs text-rose-400 mb-3">不是劝退，只是提前让你知道可能要面对什么</p>
    <ul class="space-y-2">
      {c.notSuitableFor.map((item) => (
        <li class="flex gap-2 text-sm text-slate-700 leading-relaxed">
          <span class="text-rose-300 mt-0.5 shrink-0">•</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- ═══ 6. 常见误解 ═══ -->
  <section class="bg-slate-50 p-5 rounded-xl border border-slate-100">
    <h2 class="font-semibold text-slate-800 mb-3 flex items-center gap-2 text-base">
      <span class="text-lg">⚠️</span>常见误解
    </h2>
    <ul class="space-y-3">
      {c.commonMisconceptions.map((item) => (
        <li class="flex gap-2 text-sm text-slate-600 leading-relaxed">
          <span class="text-amber-400 mt-0.5 shrink-0 font-bold">✕</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- ═══ 7. 真实学习场景 ═══ -->
  <section class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
    <h2 class="font-semibold text-slate-800 mb-3 flex items-center gap-2 text-base">
      <span class="text-lg">🎓</span>真实学习场景
    </h2>
    <ul class="space-y-2">
      {c.realScenes.map((item) => (
        <li class="flex gap-2 text-sm text-slate-600 leading-relaxed">
          <span class="text-slate-300 mt-0.5 shrink-0">•</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- ═══ 8. 未来可能方向 ═══ -->
  <section class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
    <h2 class="font-semibold text-slate-800 mb-3 flex items-center gap-2 text-base">
      <span class="text-lg">🚀</span>未来可能方向
    </h2>
    <p class="text-xs text-slate-400 mb-3">以下只是常见的出路，不代表全部。每个人的路都不一样。</p>
    <ul class="space-y-2">
      {c.futurePaths.map((item) => (
        <li class="flex gap-2 text-sm text-slate-600 leading-relaxed">
          <span class="text-slate-300 mt-0.5 shrink-0">•</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- ═══ 9. 避坑提醒 ═══ -->
  <section class="bg-amber-50 p-5 rounded-xl border border-amber-100">
    <h2 class="font-semibold text-amber-800 mb-3 flex items-center gap-2 text-base">
      <span class="text-lg">⚡</span>避坑提醒
    </h2>
    <ul class="space-y-2">
      {c.pitfalls.map((item) => (
        <li class="flex gap-2 text-sm text-slate-700 leading-relaxed">
          <span class="text-amber-400 mt-0.5 shrink-0">!</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- ═══ 10. 相关专业区别 ═══ -->
  {
    c.relatedMajors.length > 0 && (
      <section class="bg-blue-50/50 p-5 rounded-xl border border-blue-100">
        <h2 class="font-semibold text-blue-800 mb-3 flex items-center gap-2 text-base">
          <span class="text-lg">🔗</span>容易混淆的专业
        </h2>
        <p class="text-xs text-blue-400 mb-3">这几个专业名字或方向接近，帮你分清楚。</p>
        <ul class="space-y-3">
          {c.relatedMajors.map((related) => (
            <li class="text-sm leading-relaxed">
              <div class="flex items-baseline gap-2 flex-wrap">
                <span class="font-medium text-slate-800">
                  {related.slug ? (
                    <a href={`/majors/${related.gateSlug ?? c.gateSlug}/${related.slug}`} class="hover:text-primary transition-colors underline underline-offset-2 decoration-slate-300 hover:decoration-primary">
                      {related.name}
                    </a>
                  ) : related.name}
                </span>
                <span class="text-blue-300 text-xs">
                  {currentName ? `和 ${currentName}` : 'vs'}
                </span>
              </div>
              <p class="text-slate-600 mt-0.5">{related.diff}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <!-- ═══ 共建与纠错入口 ═══ -->
  <footer class="space-y-4">
    <!-- 贡献人（显眼卡片） -->
    {(c.contributors && c.contributors.length > 0) && (
      <div class="bg-gradient-to-r from-primary-light/60 to-blue-50/60 p-5 rounded-xl border border-primary-border/50">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-lg">🙋</span>
          <h3 class="text-sm font-semibold text-slate-800">内容贡献者</h3>
          <span class="text-[11px] text-primary bg-primary/10 px-2 py-0.5 rounded-full font-medium">真人学生</span>
        </div>
        <div class="space-y-2">
          {c.contributors.map((con) => (
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center text-sm font-bold text-primary shrink-0">
                {con.name.charAt(0)}
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-slate-800">{con.name}</p>
                <p class="text-xs text-slate-500">{con.role}</p>
              </div>
              <span class="text-[11px] text-green-600 bg-green-50 px-2 py-0.5 rounded-full shrink-0">✓ 已核实学生身份</span>
            </div>
          ))}
        </div>
        <p class="text-[11px] text-slate-400 mt-3 pt-3 border-t border-primary-border/30">
          以上内容由该专业在读学生编写或审核。比起官方介绍，他们更懂真实的学习体验。
        </p>
      </div>
    )}
    <!-- 纠错入口 -->
    <div class="bg-slate-50/80 p-5 rounded-xl border border-slate-200 text-center">
      <p class="text-sm text-slate-600 mb-2">
        你是这个专业的学生或毕业生？发现内容有不对或不准确的地方？
      </p>
      <a
        href="/contribute"
        class="inline-flex items-center gap-1 text-sm text-primary hover:underline font-medium"
      >
        来共建我们 & 纠错
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
      {c.updatedAt && (
        <p class="text-xs text-slate-400 mt-2">内容更新于 {c.updatedAt}</p>
      )}
    </div>
  </footer>

</article>
