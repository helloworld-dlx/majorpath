---
import Layout from '../../../../layouts/Layout.astro';
import StatusBadge from '../../../../components/ui/StatusBadge.astro';
import MajorDetailTemplate from '../../../../components/ui/MajorDetailTemplate.astro';
import { catalog } from '../../../../data/catalog';
import { majorDetails } from '../../../../data/major-details';

export function getStaticPaths() {
  const paths: { params: { gate: string; category: string; major: string } }[] = [];
  for (const gate of catalog.gates) {
    for (const cat of gate.categories) {
      for (const major of cat.majors) {
        paths.push({
          params: { gate: gate.slug, category: cat.slug, major: major.slug },
        });
      }
    }
  }
  return paths;
}

const { gate, category, major } = Astro.params;

const gateData = catalog.gates.find((g) => g.slug === gate);
const catData = gateData?.categories.find((c) => c.slug === category);
const majorData = catData?.majors.find((m) => m.slug === major);

const detailKey = `${gate}/${category}/${major}`;
const detailContent = majorDetails[detailKey] ?? null;
---

<Layout
  title={majorData ? `${majorData.name} | ${catData?.name ?? category} | 专业目录` : '专业详情'}
  description={majorData?.summary}
>
  <section class="py-10 px-4">
    <div class="max-w-3xl mx-auto">
      {/* Breadcrumb */}
      <nav class="text-sm text-slate-400 mb-6">
        <a href="/majors" class="hover:text-primary transition-colors">专业目录</a>
        <span class="mx-2">/</span>
        <a href={`/majors/${gate}`} class="hover:text-primary transition-colors">{gateData?.name ?? gate}</a>
        <span class="mx-2">/</span>
        <a href={`/majors/${gate}/${category}`} class="hover:text-primary transition-colors">{catData?.name ?? category}</a>
        <span class="mx-2">/</span>
        <span class="text-slate-600">{majorData?.name ?? major}</span>
      </nav>

      {
        majorData ? (
          <>
            {/* 具体专业头部 */}
            <header class="border-b border-slate-100 pb-6 mb-6">
              <div class="flex items-center gap-3 mb-2">
                <h1 class="text-2xl font-bold text-slate-900">{majorData.name}</h1>
                <StatusBadge status={majorData.status} size="md" />
              </div>
              {majorData.summary && (
                <p class="text-slate-600 mt-2">{majorData.summary}</p>
              )}
              <p class="text-xs text-slate-400 mt-2">
                代码 {majorData.code}
                {majorData.tags && majorData.tags.length > 0 && (
                  <span class="ml-2">
                    {majorData.tags.map((tag) => (
                      <span class="inline-block px-1.5 py-0.5 bg-slate-100 text-slate-500 rounded text-xs mr-1">
                        {tag}
                      </span>
                    ))}
                  </span>
                )}
              </p>
            </header>

            {/* 详情内容 */}
            {detailContent ? (
              <MajorDetailTemplate
                content={detailContent}
                reviewStatus={detailContent.reviewStatus}
                currentName={majorData?.name}
              />
            ) : (
              <div class="text-center py-12 bg-slate-50 rounded-xl border border-slate-100">
                <p class="text-3xl mb-3">🚧</p>
                <p class="text-slate-500 text-sm mb-2">
                  该专业详情正在编写中，敬请期待
                </p>
                <p class="text-xs text-slate-400">
                  感谢你的耐心，可以先看看该专业类的其他专业有没有内容
                </p>
                <a
                  href={`/majors/${gate}/${category}`}
                  class="inline-block mt-4 text-sm text-primary hover:underline"
                >
                  返回 {catData?.name ?? category}
                </a>
              </div>
            )}
          </>
        ) : (
          <div class="text-center py-16 text-slate-500">
            <p class="text-4xl mb-4">🔍</p>
            <p class="text-lg font-medium text-slate-600 mb-2">专业页面未找到</p>
            <p class="text-sm text-slate-400">请检查链接是否正确</p>
            <a href="/majors" class="inline-block mt-4 text-sm text-primary hover:underline">返回专业目录</a>
          </div>
        )
      }
    </div>
  </section>
</Layout>